# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real credentials.

# PostgreSQL connection string.
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
#
# Local example (after `createdb productdb`):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/productdb
#
# Neon example (copy the "Connection string" from your Neon project dashboard;
# Neon requires sslmode=require):
# DATABASE_URL=postgresql://alex:AbCdEf123@ep-cool-name-12345.us-east-2.aws.neon.tech/productdb?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/productdb

# Comma-free single origin allowed to call this API from a browser.
# Use "*" during local development/grading. In real production, set this
# to your actual frontend's URL, e.g. https://myapp.com
ALLOWED_ORIGINS=*

# Optional: override how many products scripts/seed.py generates.
# Defaults to 200000 if not set.
SEED_TOTAL_PRODUCTS=200000

# Optional: override how many rows scripts/seed.py inserts per batch.
# Defaults to 5000 if not set.
SEED_BATCH_SIZE=5000
